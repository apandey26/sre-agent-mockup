  },
  "hypotheses": [
    {
      "id": "h1",
      "title": "Recent deployment v2.4.1 introduced N+1 query",
      "confidence": 87,
      "status": "VALIDATED",
      "statusColor": "green",
      "evidenceCount": 3,
      "sourceIcons": [
        "nr",
        "github",
        "argocd"
      ],
      "skills": [
        "Deployment diff",
        "Metric correlation",
        "Log analysis"
      ],
      "evidences": [
        {
          "id": "e1",
          "type": "nrql",
          "title": "Latency spike correlated with deployment",
          "query": "SELECT percentile(duration, 99) FROM Transaction WHERE appName = 'checkout-service' SINCE 1 hour ago TIMESERIES 1 minute",
          "interpretation": "p99 latency jumped from 450ms to 2.3s at 14:23 UTC, exactly 12 minutes after deployment v2.4.1 completed at 14:11 UTC. The spike is sustained and shows no signs of recovery.",
          "chartType": "line",
          "verifyUrl": "/nrql-editor?query=...",
          "skill": "Metric correlation"
        },
        {
          "id": "e2",
          "type": "github",
          "title": "Deployment diff shows ORM change",
          "query": "git diff v2.4.0..v2.4.1 -- src/checkout/order.py",
          "interpretation": "Commit abc123 by @sarah-k removed `select_related('order_items')` from the checkout query. This eliminates eager loading, causing an N+1 query pattern under load.",
          "chartType": "diff",
          "skill": "Deployment diff"
        },
        {
          "id": "e3",
          "type": "nrql",
          "title": "Database query count spike",
          "query": "SELECT count(*) FROM Span WHERE name LIKE 'Datastore/%' AND appName = 'checkout-service' SINCE 1 hour ago TIMESERIES 1 minute",
          "interpretation": "Database query count increased 47x (from ~120/min to ~5,640/min) at the same time as the latency spike. This is consistent with an N+1 query pattern where each order loads items individually.",
          "chartType": "area",
          "skill": "NRQL query builder"
        }
      ]
    },
    {
      "id": "h2",
      "title": "Database connection pool exhaustion",
      "confidence": 12,
      "status": "INVALIDATED",
      "statusColor": "red",
      "evidenceCount": 2,
      "sourceIcons": [
        "nr"
      ],
      "skills": [
        "Metric correlation",
        "K8s diagnostics"
      ],
      "evidences": [
        {
          "id": "e4",
          "type": "nrql",
          "title": "Connection pool utilization",
          "query": "SELECT average(apm.service.datastore.connectionPool.size) FROM Metric WHERE appName = 'checkout-service' SINCE 1 hour ago TIMESERIES",
          "interpretation": "Connection pool utilization is at 34%, well below the 80% warning threshold. Pool exhaustion is not the cause.",
          "chartType": "line",
          "skill": "Metric correlation"
        },
        {
          "id": "e5",
          "type": "nrql",
          "title": "Connection wait time",
          "query": "SELECT average(databaseDuration) FROM Transaction WHERE appName = 'checkout-service' SINCE 1 hour ago TIMESERIES",
          "interpretation": "Connection wait times are elevated but caused by query volume, not pool exhaustion. The pool has capacity headroom.",
          "chartType": "line",
          "skill": "K8s diagnostics"
        }
      ]
    },
    {
      "id": "h3",
      "title": "Upstream payment-gateway degradation",
      "confidence": 34,
      "status": "INCONCLUSIVE",
      "statusColor": "amber",
      "evidenceCount": 1,
      "sourceIcons": [
        "nr"
      ],
      "skills": [
        "Metric correlation"
      ],
      "evidences": [
        {
          "id": "e6",
          "type": "nrql",
          "title": "Payment-gateway response times",
          "query": "SELECT percentile(duration, 99) FROM Transaction WHERE appName = 'payment-gateway' SINCE 1 hour ago TIMESERIES",
          "interpretation": "Payment-gateway shows a minor latency increase (180ms to 220ms) but within normal variance. Could be a downstream effect of checkout-service's increased DB load. Not likely root cause.",
          "chartType": "line",
          "skill": "Metric correlation"
        }
      ]
    }
  ],
  "subHypotheses": {
    "h1": [
      {
        "id": "h1a",
        "parentId": "h1",
        "title": "N+1 query in checkout flow",
        "confidence": 92,
        "status": "VALIDATED",
        "statusColor": "green",
        "evidenceCount": 2,
        "evidences": [
          {
            "id": "e7",
            "type": "nrql",
            "title": "Checkout transaction trace",
            "query": "SELECT * FROM Span WHERE transactionId = 'tx-abc-123' AND name LIKE 'Datastore/%'",
            "interpretation": "A single checkout transaction now makes 47 individual SELECT queries for order_items, instead of 1 joined query. Each query takes ~8ms, totaling ~376ms of added latency per request."
          },
          {
            "id": "e8",
            "type": "github",
            "title": "ORM change confirmation",
            "query": "Commit abc123: removed select_related('order_items')",
            "interpretation": "The exact line change that removed eager loading is confirmed in the deployment diff. This is the definitive cause."
          }
        ]
      },
      {
        "id": "h1b",
        "parentId": "h1",
        "title": "Missing index on order_items table",
        "confidence": 15,
        "status": "INVALIDATED",
        "statusColor": "red",
        "evidenceCount": 1,
        "evidences": [
          {
            "id": "e9",
            "type": "nrql",
            "title": "Query explain plan",
            "query": "Database slow query log analysis for order_items table",
            "interpretation": "Index on order_items(order_id) exists and is being used. Individual queries are fast (~8ms each). The problem is the quantity of queries, not their individual performance."
          }
        ]
      }
    ]
  },
