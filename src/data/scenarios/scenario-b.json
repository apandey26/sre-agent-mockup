    "mcpTools": "NR (26 tools), K8s (5), Git (9), PagerDuty (3)"
  },
  "hypotheses": [
    {
      "id": "h1",
      "title": "TLS certificate expiry on auth-service",
      "confidence": 92,
      "status": "VALIDATED",
      "statusColor": "green",
      "evidenceCount": 4,
      "sourceIcons": [
        "nr",
        "k8s",
        "slack"
      ],
      "evidences": [
        {
          "id": "e1",
          "type": "nrql",
          "title": "5xx error spike starting at 03:14 UTC",
          "query": "SELECT count(*) FROM Transaction WHERE appName = 'api-gateway' AND httpResponseCode >= 500 SINCE 8 hours ago TIMESERIES 5 minutes",
          "interpretation": "5xx errors jumped from 0.1% to 12% at exactly 03:14 UTC. All 5xx errors are 502 Bad Gateway, indicating upstream connection failures to auth-service.",
          "skill": "Cert/TLS analysis"
        },
        {
          "id": "e2",
          "type": "nrql",
          "title": "auth-service connection errors",
          "query": "SELECT count(*) FROM Span WHERE name = 'External/auth-service/verify' AND error IS true SINCE 8 hours ago TIMESERIES",
          "interpretation": "Connection to auth-service started failing with TLS handshake errors at 03:14 UTC. Error message: 'certificate has expired'. The auth-service TLS cert had a 90-day validity and was not renewed.",
          "skill": "Metric correlation"
        },
        {
          "id": "e3",
          "type": "k8s",
          "title": "Certificate secret last modified",
          "query": "kubectl get secret auth-service-tls -n production -o jsonpath='{.metadata.creationTimestamp}'",
          "interpretation": "The TLS secret auth-service-tls was created 90 days ago (2026-01-09) and has not been rotated. The cert expired at 03:14 UTC today, exactly 90 days from creation.",
          "skill": "Log analysis"
        },
        {
          "id": "e4",
          "type": "slack",
          "title": "Slack thread confirmation",
          "query": "#inc-api-gateway thread messages",
          "interpretation": "Mike T. confirmed at 03:45: 'Checked the cert \u2014 it expired at 03:14. Same thing happened 90 days ago with INV-0623. We need to automate cert rotation.'",
          "skill": "NRQL query builder"
        }
      ],
      "skills": [
        "Cert/TLS analysis",
        "Metric correlation",
        "Log analysis"
      ]
    },
    {
      "id": "h2",
      "title": "Rate limiting misconfiguration",
      "confidence": 8,
      "status": "INVALIDATED",
      "statusColor": "red",
      "evidenceCount": 1,
      "sourceIcons": [
        "nr"
      ],
      "evidences": [
        {
          "id": "e5",
          "type": "nrql",
          "title": "Rate limiter status",
          "query": "SELECT count(*) FROM Transaction WHERE appName = 'api-gateway' AND httpResponseCode = 429 SINCE 8 hours ago",
          "interpretation": "Rate limiting is functioning normally. 429 responses are within baseline. The 502 errors are not rate-limiting related.",
          "skill": "Cert/TLS analysis"
        }
      ],
      "skills": [
        "Metric correlation",
        "K8s diagnostics"
      ]
    },
    {
      "id": "h3",
      "title": "DNS resolution failures",
      "confidence": 6,
      "status": "INVALIDATED",
      "statusColor": "red",
      "evidenceCount": 1,
      "sourceIcons": [
        "nr"
      ],
      "evidences": [
        {
          "id": "e6",
          "type": "nrql",
          "title": "DNS resolution metrics",
          "query": "SELECT average(dnsLookupDuration) FROM Span WHERE appName = 'api-gateway' SINCE 8 hours ago TIMESERIES",
          "interpretation": "DNS resolution times are normal (avg 2.3ms). No DNS failures detected. The connection errors are at the TLS layer, not DNS.",
          "skill": "Cert/TLS analysis"
        }
      ],
      "skills": [
        "Log analysis"
      ]
    },
    {
      "id": "h4",
      "title": "Memory leak in connection pooling",
      "confidence": 28,
      "status": "INCONCLUSIVE",
      "statusColor": "amber",
      "evidenceCount": 2,
      "sourceIcons": [
        "nr"
      ],
      "evidences": [
        {
          "id": "e7",
          "type": "nrql",
          "title": "Memory usage trend",
          "query": "SELECT average(memoryUsedPercent) FROM SystemSample WHERE hostname LIKE 'api-gateway%' SINCE 24 hours ago TIMESERIES",
          "interpretation": "Memory usage has been slowly climbing (58% to 67% over 24h) which could indicate a leak, but this is secondary to the cert expiry. The memory trend predates the incident and may need separate investigation.",
          "skill": "Cert/TLS analysis"
        },
        {
          "id": "e8",
          "type": "nrql",
          "title": "Connection pool metrics",
          "query": "SELECT average(connectionPoolUsed) FROM Metric WHERE appName = 'api-gateway' SINCE 8 hours ago TIMESERIES",
          "interpretation": "Connection pool usage spiked to 92% during the incident but this is a symptom (failed connections aren't being released), not the cause.",
          "skill": "Metric correlation"
        }
      ],
      "skills": [
        "Metric correlation"
      ]
    }
  ],
