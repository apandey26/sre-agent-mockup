  "hypotheses": [
    {
      "id": "h1",
      "title": "Redis connection pool exhaustion",
      "confidence": 78,
      "status": "VALIDATED",
      "statusColor": "green",
      "evidenceCount": 2,
      "sourceIcons": [
        "nr",
        "k8s"
      ],
      "evidences": [
        {
          "id": "e1",
          "type": "nrql",
          "title": "Redis connection count spike",
          "query": "SELECT max(redis.connections) FROM Metric WHERE appName = 'payment-gateway' SINCE 1 hour ago TIMESERIES 1 minute",
          "interpretation": "Redis connections jumped from 45 to 200 (pool max) at 11:42 UTC. New connections are being rejected. Connection leak pattern: connections opened but not released after timeout.",
          "chartType": "line",
          "skill": "Metric correlation"
        },
        {
          "id": "e2",
          "type": "k8s",
          "title": "Pod restart loop",
          "query": "kubectl get events -n production --field-selector involvedObject.name=payment-gateway",
          "interpretation": "payment-gateway pods restarting every 4-5 minutes due to health check failures. Redis connection exhaustion causes health endpoint timeout.",
          "chartType": "events",
          "skill": "Log analysis"
        }
      ],
      "skills": [
        "Metric correlation",
        "Log analysis",
        "Deployment diff"
      ]
    },
    {
      "id": "h2",
      "title": "Downstream inventory-service failure",
      "confidence": 15,
      "status": "INVALIDATED",
      "statusColor": "red",
      "evidenceCount": 1,
      "sourceIcons": [
        "nr"
      ],
      "evidences": [
        {
          "id": "e3",
          "type": "nrql",
          "title": "inventory-service health",
          "query": "SELECT percentile(duration, 99) FROM Transaction WHERE appName = 'inventory-service' SINCE 1 hour ago TIMESERIES",
          "interpretation": "inventory-service is healthy. Response times normal (45ms p99). Not the cause.",
          "chartType": "line",
          "skill": "Metric correlation"
        }
      ],
      "skills": [
        "K8s diagnostics",
        "Log analysis"
      ]
    }
  ],
  "subHypotheses": {},
  "rootCause": {
    "validatedHypothesis": "h1",
    "summary": "Redis connection pool maxed out due to connection leak in v3.1.2. Connections opened during payment processing are not released on timeout, causing pool exhaustion under normal load.",
